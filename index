<script>
    function showPage(pageId) {
        const pages = document.querySelectorAll('.page-content');
        pages.forEach(page => page.classList.remove('active'));
        const targetPage = document.getElementById(pageId);
        if(targetPage) targetPage.classList.add('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
        
        const navLinks = document.querySelectorAll('.nav-links a');
        navLinks.forEach(link => {
            link.classList.remove('active-nav');
            if(link.getAttribute('data-page') === pageId) link.classList.add('active-nav');
        });
    }
    
    document.querySelectorAll('.nav-links a').forEach(link => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            const page = link.getAttribute('data-page');
            if(page) showPage(page);
        });
    });
    
    window.addEventListener('scroll', () => {
        const nav = document.querySelector('nav');
        if(window.scrollY > 50) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
    });
    
    const activePage = document.querySelector('.page-content.active')?.id;
    if(activePage) {
        const activeLink = document.querySelector(`.nav-links a[data-page="${activePage}"]`);
        if(activeLink) activeLink.classList.add('active-nav');
    }
</script>


